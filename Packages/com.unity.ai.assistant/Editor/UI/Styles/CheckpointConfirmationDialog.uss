.checkpointconfirmationdialog__element {
    flex-grow: 1;
}

.checkpointconfirmationdialog__element-root {
    flex-grow: 1;
}

.checkpoint-confirmation-dialog {
    padding: 12px;
    flex-grow: 1;
}

.checkpoint-confirmation-dialog__section-header {
    -unity-font-style: bold;
    font-size: 14px;
    margin-bottom: 8px;
    color: var(--muse-chat-text-primary);
}

.checkpoint-confirmation-dialog__body {
    white-space: normal;
    font-size: 12px;
    color: var(--muse-chat-text-primary);
    margin-bottom: 10px;
}

.checkpoint-confirmation-dialog__warning-banner {
    flex-direction: row;
    align-items: center;
    border-radius: 4px;
    border-width: 1px;
    border-color: var(--muse-chat-backgrounds-75);
    padding: 8px;
    margin-bottom: 10px;
}

.checkpoint-confirmation-dialog__warning-icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    margin-right: 8px;
    margin-top: 1px;
}

.checkpoint-confirmation-dialog__warning-text {
    flex-grow: 1;
    white-space: normal;
    font-size: 12px;
}

.checkpoint-confirmation-dialog__files-header {
    font-size: 12px;
    color: var(--muse-chat-text-secondary);
    margin-bottom: 4px;
}

.checkpoint-confirmation-dialog__files-container {
    flex-grow: 1;
    border-radius: 4px;
    border-width: 1px;
    border-color: var(--muse-chat-backgrounds-75);
    margin-bottom: 10px;
    overflow: hidden;
}

.checkpoint-confirmation-dialog__file-scroll {
    flex-grow: 1;
}

.checkpoint-confirmation-dialog__section-foldout {
    margin: 2px 4px;
}

.checkpoint-confirmation-dialog__section-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    margin-right: 6px;
}

.checkpoint-confirmation-dialog__section-icon--error {
    -unity-background-image-tint-color: var(--muse-chat-icon-error-color);
    --unity-image-tint-color: var(--muse-chat-icon-error-color);
}

.checkpoint-confirmation-dialog__section-icon--success {
    -unity-background-image-tint-color: var(--muse-chat-icon-success-color);
    --unity-image-tint-color: var(--muse-chat-icon-success-color);
}

.checkpoint-confirmation-dialog__footer {
    flex-direction: row;
    justify-content: flex-end;
    align-items: center;
}

.checkpoint-confirmation-dialog__button {
    min-width: 100px;
    font-size: 13px;
    margin-left: 8px;
    padding: 4px 16px;
    -unity-text-align: middle-center;
}

.checkpoint-confirmation-dialog__button--primary {
    -unity-font-style: bold;
}
