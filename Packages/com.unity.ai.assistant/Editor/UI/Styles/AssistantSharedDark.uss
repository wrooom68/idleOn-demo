:root {
    --muse-chat-backgrounds-50: #191919;
    --muse-chat-backgrounds-75: #232323;
    --muse-chat-backgrounds-100: #282828;
    --muse-chat-backgrounds-125: #303030;
    --muse-chat-backgrounds-150: #383838;
    --muse-chat-backgrounds-175: #444444;
    --muse-chat-backgrounds-200: #3c3c3c;
    --muse-chat-backgrounds-250: #3f3f3f;
    --muse-chat-foregrounds-300: #4c4c4c;
    --muse-chat-foregrounds-310: #4d4d4d;
    --muse-chat-foregrounds-320: #595959;
    --muse-chat-backgrounds-350: #5f5f5f;
    --muse-chat-foregrounds-25: #676767;
    --muse-chat-text-primary: #fff;
    --muse-chat-text-primary-inverted: #090909;
    --muse-chat-text-secondary: rgba(210, 210, 210, 0.5);
    --muse-chat-text-thoughts: rgba(230, 230, 230, 0.65);
    --muse-chat-text-answers: rgba(230, 230, 230, 1);
    --muse-chat-conversation-dragger: #4d4d4d;
    --muse-chat-conversation-dragger-hover: #595959;
    --muse-chat-text-secondary-on-background-50: rgba(160, 160, 160, 1);
    --muse-chat-text-arguments:  rgba(204, 170, 102, 0.75);
    --muse-chat-primary-500: #656565;
    --muse-chat-accent-50: #2c5d87;
    --muse-chat-accent-100: #4c7eff;
    --muse-chat-button-disabled: rgba(88, 88, 88, 0.3);
    --muse-chat-button-pressed: #46607c;
    --muse-chat-icon-missing: #d33c79;
    --muse-chat-icon-success-color: #4CAF50;
    --muse-chat-icon-warning-color: #E6B00C;
    --muse-chat-icon-error-color: #FF534A;
    --muse-chat-warning-background-color: rgba(244, 188, 2, 0.3);
    --muse-chat-button-active: #4c607b;
    --muse-chat-prefab-color: #7baefa;
    --muse-chat-code-mark-error: rgba(185, 39, 39, 0.3);
    --muse-chat-code-mark-info: rgba(36, 36, 192, 0.3);
    --muse-chat-image-hover-tint: #d2d2d2;
    --muse-chat-separator-line: rgba(255,255,255,0.1);
    --muse-chat-feedback-status-text-color: #d2d2d2;
    --muse-chat-feedback-status-link-color: #7baefa;


    /* Legacy Colors To Remove */
    --muse-chat-color-invalid: #dc00ff;

    /* Image overlay badge */
    --muse-chat-image-overlay: rgba(0, 0, 0, 0.55);
    --muse-chat-image-overlay-hover: rgba(0, 0, 0, 0.75);

    /* Specialized overrides for dark + light discrepancy */
    --muse-chat-popup-hover: var(--muse-chat-foregrounds-300);
    --muse-chat-popup-tab-hover: #cbcbcb;
}

.-muse-chat-panel {
    background-color: var(--muse-chat-backgrounds-150);
}

.muse-chat-icon {
    ---unity-image-tint-color: blue;
}

.mui-icon-empty {
    background-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/empty.png');
}

.mui-icon-empty-margin {
    background-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/empty.png');
    width: 28px;
    height: 14px;
}

.mui-icon-history {
    background-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/UndoHistory.png');
}

.mui-icon-copy {
    background-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/Copy.png');
}

.mui-icon-save {
    background-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/SaveAs.png');
}

.mui-icon-edit {
    background-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/Code.png');
}

.mui-icon-delete {
    background-image: resource('d_console.erroricon');
}

.mui-icon-upvote {
    background-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/ThumbsUp.png');
}

.mui-icon-downvote {
    background-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/ThumbsDown.png');
}

.mui-icon-tick {
    background-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/CompletedTask.png');
}

.mui-icon-star-filled-white {
    background-image: url("project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/Favorites.png");
}

.mui-icon-star-filled-grey {
    --unity-image: url("project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/Favorites.png");
    --unity-image-tint-color: var(--muse-chat-text-secondary);
}

.mui-icon-star-filled-grey:hover {
    --unity-image-tint-color: var(--muse-chat-image-hover-tint);
}

.mui-icon-close-s-trimmed {
    background-image: url("project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/Close_S_Trimmed.png");
}

.mui-icon-close {
    --unity-image: url("project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/Close.png");
}

/* Attachment close buttons: override default Button theme styles */
.mui-ca-remove-overlay {
    background-color: var(--muse-chat-image-overlay);
}

.mui-ca-remove-overlay:hover {
    background-color: var(--muse-chat-image-overlay-hover);
}

.mui-ca-remove-overlay:active {
    background-color: var(--muse-chat-image-overlay-hover);
}

.mui-ca-remove-button {
    background-color: var(--muse-chat-image-overlay);
}

.mui-ca-remove-button:hover {
    background-color: var(--muse-chat-image-overlay-hover);
}

.mui-ca-remove-button:active {
    background-color: var(--muse-chat-image-overlay-hover);
}

.mui-ca-remove-overlay .mui-icon-close {
    --unity-image-tint-color: white;
}

.mui-ca-remove-button .mui-icon-close {
    --unity-image-tint-color: white;
}

.mui-icon-more-vertical {
    --unity-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/IconMoreVertical.svg');
    --unity-image-size: scale-to-fit;
}

.mui-attachment-clear-all-button,
.mui-attachment-clear-all-button:hover,
.mui-attachment-clear-all-button:active {
    background-color: transparent;
}

.mui-icon-arrow-square-in {
    background-image: url("project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/ArrowSquareIn.png");
}

.mui-icon-undo {
    --unity-image:resource("Icons/d_UndoHistory.png");
}

.mui-icon-error {
    background-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/Error.png');
}

.mui-icon-warn {
    background-image: url("project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/Warning.png");
}

.mui-icon-warn-large {
    background-image: url("project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/Warning.png");
}

.mui-icon-info {
    background-image: resource('d_console.infoicon.sml@2x');
}

.mui-icon-game-object {
    --unity-image: resource('d_GameObject Icon');
}

.mui-icon-console {
    --unity-image: resource('d_UnityEditor.ConsoleWindow');
}

.mui-icon-pick {
    background-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/Target.png');
}

.mui-icon-settings {
    --unity-image: resource('d_Settings');
}

.mui-icon-shortcut {
    background-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/Shortcuts.png');
}

.mui-icon-arrow-up {
    background-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/ArrowUp.png');
}

.mui-icon-arrow-down {
    background-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/ArrowDown.png');
}

.mui-icon-arrow-caret-up {
    --unity-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/ArrowCaretUp.png');
}

.mui-icon-arrow-caret-down {
    --unity-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/ArrowCaretDown.png');
}

.mui-icon-arrow-caret-right {
    --unity-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/ArrowCaretUp.png');
    rotate: 90deg;
}

.mui-icon-prefab {
    --unity-image: resource('d_Prefab Icon');
}

.mui-icon-caret-down {
    background-image: resource('d_dropdown@2x');
}

.mui-icon-checkmark {
    background-image: resource('check');
    -unity-background-image-tint-color: var(--muse-chat-image-hover-tint);
}

.mui-icon-checkmark-green {
    background-image: resource('check');
    -unity-background-image-tint-color: var(--muse-chat-icon-success-color);
}

.mui-icon-feedback-error {
    background-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/Error.png');
    -unity-background-image-tint-color: var(--muse-chat-icon-error-color);
}

.mui-icon-double-checkmark {
    background-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/DoubleCheckmark_2x.png');
}

.mui-icon-arrows-counter-clockwise {
    background-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/Refresh.png');
}

.mui-icon-plus {
    background-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/Plus.png');
}

.mui-icon-menu {
    background-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/List.png');
}

.mui-icon-arrow-left {
    background-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/ArrowLeft.png');
}

.mui-icon-arrow-right {
    background-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/ArrowRight.png');
}

.mui-icon-sparkle {
    --unity-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/Sparkle.svg');
    --unity-image-size: scale-to-fit;
}

.mui-icon-lightning {
    --unity-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/Lightning.svg');
    --unity-image-size: scale-to-fit;
}

.mui-icon-sort-descending {
    --unity-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/SortDescending.svg');
    --unity-image-size: scale-to-fit;
}

.mui-icon-stop-square {
    background-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/Stop.png');
}

.mui-icon-wait {
    --unity-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/Wait.png');
}

.mui-icon-enlarge {
    background-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/Enlarge.png');
}

.mui-icon-caret-up-down-maximize {
    background-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/CaretUpDownMaximize.png');
    -unity-background-scale-mode: scale-to-fit;
}

.mui-icon-caret-up-down-minimize {
    background-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/CaretUpDownMinimize.png');
    -unity-background-scale-mode: scale-to-fit;
}

.mui-icon-shrink {
    background-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/Shrink.png');
}

.mui-icon-list-checks {
    background-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/ListChecks.png');
}

.mui-icon-context-virtual {
    background-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/VirtualContext.png');
}

.mui-icon-pen {
    background-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/Pen.png');
}

.mui-icon-trash {
    background-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/SmallX.png');
}

.mui-icon-search {
    background-image: resource('d_Search Icon');
}

.mui-icon-folder {
    background-image: resource('d_Folder Icon');
}

.mui-icon-checkpoint {
    background-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/Checkpoint.png');
}


/* Animation frames for the progress icon using Unity logo cycle */
.mui-icon-progress-frame-0 {
    background-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/UnityLogoCylce_Dark_1.png');
}

.mui-icon-progress-frame-1 {
    background-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/UnityLogoCylce_Dark_2.png');
}

.mui-icon-progress-frame-2 {
    background-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/UnityLogoCylce_Dark_3.png');
}

.mui-icon-progress-frame-3 {
    background-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/UnityLogoCylce_Dark_4.png');
}

.mui-icon-progress-frame-4 {
    background-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/UnityLogoCylce_Dark_5.png');
}

.mui-icon-progress-frame-5 {
    background-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/UnityLogoCylce_Dark_6.png');
}

.mui-icon-slash {
    background-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/Slash.png');
}

.mui-icon-code-block {
    background-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/CodeBlock.png');
}

.mui-icon-maximize {
    background-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/Maximize.png');
}

.mui-icon-text-asset {
    background-image: url('project://database/Packages/com.unity.ai.assistant/Editor/UI/Assets/icons/TextAsset.png');
}

.mui-icon-tint-success {
    -unity-background-image-tint-color: var(--muse-chat-icon-success-color);
}
