.disclaimer-box {
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.1);
    border-radius: 4px;
    padding: 12px;
    margin-top: 12px;
    margin-bottom: 14px;
}

.disclaimer-scroll {
    flex-grow: 1;
}

.disclaimer-heading-row {
    flex-direction: row;
    align-items: flex-start;
}

.disclaimer-info-icon {
    width: 16px;
    height: 16px;
    margin-right: 6px;
    flex-shrink: 0;
}

.disclaimer-heading {
    white-space: normal;
    font-size: 14px;
    -unity-font-style: bold;
    margin-bottom: 10px;
}

.disclaimer-intro {
    white-space: normal;
    font-size: 12px;
    margin-bottom: 8px;
}

.disclaimer-bullet-row {
    flex-direction: row;
    align-items: flex-start;
    margin-top: 8px;
    padding-left: 4px;
}

.disclaimer-bullet-glyph {
    width: 16px;
    flex-shrink: 0;
    font-size: 12px;
}

.disclaimer-bullet-text {
    flex-grow: 1;
    flex-shrink: 1;
    white-space: normal;
    font-size: 12px;
}

.disclaimer-footer {
    white-space: normal;
    font-size: 12px;
    -unity-font-style: italic;
    margin-top: 16px;
}

.disclaimer-button-row {
    flex-direction: row;
    justify-content: flex-end;
    margin-top: 12px;
}

.disclaimer-accept-button {
    height: 28px;
    min-width: 80px;
}

.disclaimer-signin-label {
    display: none;
    white-space: normal;
    font-size: 12px;
    -unity-text-align: middle-center;
    height: 28px;
    margin-top: 12px;
}
