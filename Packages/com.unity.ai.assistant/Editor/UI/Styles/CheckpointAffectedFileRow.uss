.checkpoint-affected-file-row {
    flex-direction: row;
    align-items: center;
    padding: 2px 6px;
    margin-bottom: 4px;
}

.checkpoint-affected-file-row__icon {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    margin-right: 6px;
}

.checkpoint-affected-file-row__path {
    flex-grow: 1;
    font-size: 12px;
    color: var(--muse-chat-text-primary);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    -unity-text-align: middle-left;
}
