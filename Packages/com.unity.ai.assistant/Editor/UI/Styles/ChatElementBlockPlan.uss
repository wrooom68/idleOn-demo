.mui-chat-plan-container {
    background-color: var(--muse-chat-backgrounds-100);
    border-radius: var(--muse-chat-border-radius);
    padding: 8px 12px;
    margin-bottom: 4px;
}

.mui-chat-plan-entry {
    color: var(--muse-chat-text-answers);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}
