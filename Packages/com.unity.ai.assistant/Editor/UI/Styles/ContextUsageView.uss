.mui-context-usage {
    flex-direction: row;
    align-items: center;
    display: none;
}

.mui-context-usage-warning .mui-context-usage-label {
    color: var(--muse-chat-icon-warning-color);
}

.mui-context-usage-label {
    font-size: 11px;
    margin-right: 4px;
    -unity-font-style: normal;
}

.mui-context-usage-ring {
    width: 14px;
    height: 14px;
}
