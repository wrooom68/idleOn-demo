.assistantdropdown__element {
    position: absolute;
}

.assistant-dropdown {
    background-color: var(--muse-chat-backgrounds-200);
    border-radius: 4px;
    border-width: 1px;
    border-color: var(--muse-chat-foregrounds-310);
    padding: 2px 0;
}

.assistant-dropdown-scroll {
    max-height: 300px;
}
