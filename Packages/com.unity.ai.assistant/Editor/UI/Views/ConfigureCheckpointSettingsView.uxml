<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements">
    <ui:VisualElement class="configure-checkpoint-settings-view">
        <ui:Label text="Checkpoint Settings" class="checkpoint-settings-title" />
        <ui:VisualElement class="checkpoint-settings-content">

            <ui:VisualElement class="checkpoint-settings-row">
                <ui:Label text="Enable Checkpoints" class="checkpoint-settings-label" />
                <ui:VisualElement class="checkpoint-settings-value checkpoint-toggle-container">
                    <ui:Toggle name="checkpointEnabledToggle"
                               tooltip="Creates automatic git snapshots of your project before each prompt, allowing you to restore to previous states." />
                    <ui:VisualElement name="checkpointInitializingIndicator" class="checkpoint-initializing">
                        <ui:Label name="initializingLabel" text="Initializing..." />
                    </ui:VisualElement>
                </ui:VisualElement>
            </ui:VisualElement>
            
            <ui:VisualElement name="checkpointDisclaimerContainer" class="assistant-settings-info-box">
                <ui:Image class="mui-icon-info checkpoint-disclaimer-icon" />
                <ui:Label name="checkpointDisclaimerText"
                          text="When a prompt is sent, a checkpoint gets created, which automatically saves all open scenes and assets. Restoring a checkpoint will overwrite your current project state and may result in loss of unsaved work. Large projects may experience slower checkpoint creation." />
            </ui:VisualElement>

            <ui:VisualElement class="checkpoint-settings-row">
                <ui:Label text="Select git instance" class="checkpoint-settings-label" />
                <ui:VisualElement class="checkpoint-settings-value">
                    <ui:DropdownField name="gitInstanceDropdown" />
                </ui:VisualElement>
            </ui:VisualElement>

            <ui:VisualElement name="gitValidationContainer" class="checkpoint-validation-row">
                <ui:Label name="gitValidationLabel" />
            </ui:VisualElement>

            <ui:VisualElement name="customGitPathContainer" class="checkpoint-settings-row">
                <ui:Label text="Git Path" class="checkpoint-settings-label" />
                <ui:VisualElement class="checkpoint-settings-value">
                    <ui:TextField name="customGitPathField" />
                    <ui:Button name="browseGitPathButton" text="Browse" class="checkpoint-browse-button" />
                </ui:VisualElement>
            </ui:VisualElement>

            <ui:VisualElement name="gitValidationErrorContainer" class="checkpoint-error-container">
                <ui:Image class="mui-icon-warn-large checkpoint-error-icon" />
                <ui:Label name="gitValidationErrorText" />
            </ui:VisualElement>

            <ui:VisualElement class="checkpoint-settings-row">
                <ui:Label text="Repository location" class="checkpoint-settings-label" />
                <ui:VisualElement class="checkpoint-settings-value">
                    <ui:TextField name="repositoryLocationField" readonly="true" />
                    <ui:Button name="openRepositoryButton" text="Open" class="checkpoint-browse-button" />
                </ui:VisualElement>
            </ui:VisualElement>

            <ui:VisualElement class="checkpoint-settings-row">
                <ui:Label text="Delete checkpoints after" class="checkpoint-settings-label" />
                <ui:VisualElement class="checkpoint-settings-value checkpoint-retention-row">
                    <ui:DropdownField name="checkpointRetentionWeeksDropdown" />
                    <ui:Label text="Weeks" class="checkpoint-retention-suffix" />
                </ui:VisualElement>
            </ui:VisualElement>

            <ui:Label text="Verification" class="checkpoint-settings-title" />
            <ui:VisualElement name="verificationSection" class="checkpoint-verification-section">
                <ui:Label name="verificationStatusLabel" class="checkpoint-verification-status" />
                <ui:VisualElement name="verificationFailureGroup" class="checkpoint-verification-failure-group">
                    <ui:Label name="missingFilesHeader" class="checkpoint-missing-files-header" />
                    <ui:ScrollView name="missingFilesList" class="checkpoint-missing-files-list">
                        <ui:Label name="missingFilesContent" class="checkpoint-missing-files-content" />
                        <ui:Label name="missingFilesOverflow" class="checkpoint-missing-files-overflow" />
                    </ui:ScrollView>
                    <ui:VisualElement class="checkpoint-verification-actions">
                        <ui:Button name="retryVerificationButton" text="Retry Verification" class="checkpoint-verification-button" />
                        <ui:VisualElement class="checkpoint-initialize-anyway-group">
                            <ui:Button name="initializeAnywayButton" text="Initialize Anyway" class="checkpoint-verification-button checkpoint-initialize-anyway-button" />
                            <ui:VisualElement name="initializeAnywayWarning" class="checkpoint-initialize-anyway-warning checkpoint-initialize-anyway-warning--hidden">
                                <ui:Label text="Warning: Initializing anyway will cause data loss for the missing files when any checkpoint is restored." class="checkpoint-initialize-anyway-warning-text" />
                            </ui:VisualElement>
                        </ui:VisualElement>
                    </ui:VisualElement>
                </ui:VisualElement>
            </ui:VisualElement>
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
