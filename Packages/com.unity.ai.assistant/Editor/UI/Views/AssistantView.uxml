<ui:UXML xmlns:ui="UnityEngine.UIElements"
         xmlns:chat="Unity.AI.Assistant.Editor.SessionBanner"
         xmlns="UnityEngine.UIElements" editor-extension-mode="False">
    <ui:VisualElement name="root-panel">
        <ui:VisualElement name="root-main">
            <ui:VisualElement name="headerRoot" class="mui-header -muse-chat-panel">
                <ui:VisualElement name="headerRow" class="mui-header-row">
                    <ui:Button name="newChatButton" class="mui-action-button mui-header-button">
                        <ui:Label class="mui-action-button-label-header" text="New"/>
                    </ui:Button>
                    <ui:Label name="expandedPanelTitle" class="mui-chat-label mui-header-label mui-expanded-panel-title" picking-mode="ignore" style="display: none;"/>
                    <ui:Label name="conversationNameLabel" class="mui-chat-label mui-header-label" text="Conversation Name" picking-mode="ignore"/>
                    <ui:Button name="openSearchButton" class="mui-action-button mui-header-button">
                        <ui:Image class="mui-action-button-image-large mui-icon-search"/>
                    </ui:Button>
                    <ui:Button name="historyButton" class="mui-action-button mui-header-button">
                        <ui:Label class="mui-action-button-label-header" text="Chats"/>
                    </ui:Button>
                    <ui:Button name="expandedPanelBackButton" class="mui-action-button mui-code-block-element-button">
                        <ui:Image class="mui-action-button-image-large mui-icon-close"/>
                    </ui:Button>
                </ui:VisualElement>
                <ui:VisualElement name="searchRow" class="mui-search-row">
                    <Label text="" name="searchResultCount"/>
                    <ui:Button name="searchPreviousButton" class="mui-action-button mui-search-button">
                        <ui:Image class="mui-action-button-image mui-search-button-image mui-icon-arrow-caret-up"/>
                    </ui:Button>
                    <ui:Button name="searchNextButton" class="mui-action-button mui-search-button">
                        <ui:Image class="mui-action-button-image mui-search-button-image mui-icon-arrow-caret-down"/>
                    </ui:Button>
                </ui:VisualElement>
                <ui:VisualElement name="session-notifications-area">
                    <chat:SessionBanner name="session-notifications" picking-mode="Ignore"/>
                </ui:VisualElement>
            </ui:VisualElement>

            <ui:VisualElement name="chatContentRoot" class="mui-chat-content">
                <ui:VisualElement name="chatContentInner" class="mui-chat-content-inner">
                    <ui:VisualElement class="mui-conversation-panel">
                        <ui:VisualElement name="chatPanelRoot">
                        </ui:VisualElement>
                    </ui:VisualElement>

                    <ui:VisualElement name="emptyStateRoot" class="mui-chat-empty-state">
                        <ui:VisualElement name="emptyStateLoading" class="mui-chat-empty-state-loading">
                        </ui:VisualElement>
                        <ui:VisualElement name="emptyStateContent" class="mui-chat-empty-state-content">
                            <ui:VisualElement name="whatsNewBannerRoot"/>
                            <ui:VisualElement class="mui-chat-disclaimer">
                                <ui:Label text="Beta" class="mui-beta-chip"/>
                                <ui:Label text="Surprises and mistakes are possible." class="mui-chat-label mui-chat-disclaimer-text"/>
                                <ui:Label text="Make sure to check results, and share feedback so we can learn and improve." class="mui-chat-label mui-chat-disclaimer-text"/>
                                <ui:Label name="contentPolicyLink" enable-rich-text="true" class="mui-chat-label mui-chat-disclaimer-link"/>
                            </ui:VisualElement>
                        </ui:VisualElement>
                    </ui:VisualElement>
                </ui:VisualElement>

                <ui:VisualElement name="progressElementContainer" picking-mode="Ignore">
                </ui:VisualElement>

            </ui:VisualElement>

            <ui:VisualElement name="footerRoot" class="mui-footer -muse-chat-panel">

                <ui:VisualElement class="mui-chat-hero">
                    <ui:Image class="mui-action-button-image-large mui-icon-sparkle mui-chat-hero-icon"/>
                    <ui:Label text="What are you creating today?" class="mui-chat-hero-label"/>
                </ui:VisualElement>

                <ui:VisualElement name="chatTextFieldRoot" class="mui-chat-input-root">
                    <ui:VisualElement name="popupAnchor"/>
                </ui:VisualElement>

                <ui:VisualElement name="planPromptBannerRoot"/>

                <ui:VisualElement name="contextRoot" class="mui-chat-user-context-root">
                    <VisualElement name="dropdownToggle" class="mui-context-dropdown-toggle">
                        <Label name="dropdownToggleLabel" text="Attached items"/>
                        <Image name="contextDropdownIcon" class="mui-icon-caret-down"/>
                    </VisualElement>
                    <ui:Button name="clearContextButton" text="Clear all" class="mui-chat-clear-context-button" />
                </ui:VisualElement>

                <ui:VisualElement name="newChatTopicBarRoot" class="mui-new-chat-topic-bar-container"/>

                <ui:VisualElement name="dropZoneRoot" class="mui-chat-context-dropzone" picking-mode="Ignore">
                </ui:VisualElement>

                <ui:VisualElement name="dropZoneOverlay" picking-mode="Ignore">
                </ui:VisualElement>

            </ui:VisualElement>
        </ui:VisualElement>
        
        <ui:VisualElement name="historyPanelRoot">
        </ui:VisualElement>

        <ui:VisualElement name="chatModalPopupRoot" class="mui-chat-popup-container" picking-mode="Ignore"/>
    </ui:VisualElement>
</ui:UXML>
